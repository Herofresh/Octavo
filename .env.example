# Server
PORT=3000

# Runtime defaults
OCTAVO_RUNTIME_PROVIDER=mock
OCTAVO_RUNTIME_MODEL=mock-1

# OpenAI
OPENAI_API_KEY=
OCTAVO_OPENAI_MODEL=gpt-4.1-mini
OCTAVO_OPENAI_MODELS=gpt-4.1-mini,gpt-4.1,gpt-4o-mini,gpt-5-codex
# OCTAVO_OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini
GEMINI_API_KEY=
OCTAVO_GEMINI_MODEL=gemini-2.0-flash
OCTAVO_GEMINI_MODELS=gemini-2.0-flash,gemini-2.5-flash,gemini-2.5-pro
# OCTAVO_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Harness defaults (pi is execution harness metadata, not an LLM provider)
# OCTAVO_DEFAULT_HARNESS=pi
